; test4.lbm - test visible, enabled, style attributes and setters

(def root (qt-root))

; --- style at creation ---
(def styled (qt-widget-add-button root "Styled at creation"
             '(style "background-color: #2255aa; color: #ffffff;")))

; --- visible/enabled toggling ---
(def hbox (qt-widget-add-container root 'hbox))

(def target (qt-widget-add-button hbox "Target button"))

(def btn-hide    (qt-widget-add-button hbox "Hide"))
(def btn-show    (qt-widget-add-button hbox "Show"))
(def btn-disable (qt-widget-add-button hbox "Disable"))
(def btn-enable  (qt-widget-add-button hbox "Enable"))

; --- created hidden, then shown on demand ---
(def secret (qt-widget-add-button root "Secret button (starts hidden)"
             '(visible nil)))
(def btn-reveal (qt-widget-add-button root "Reveal secret" '(max-width 120)))

; --- style setter ---
(def hbox2 (qt-widget-add-container root 'hbox))
(def btn-red   (qt-widget-add-button hbox2 "Red"   '(max-width 60)))
(def btn-green (qt-widget-add-button hbox2 "Green" '(max-width 60)))
(def btn-reset (qt-widget-add-button hbox2 "Reset" '(max-width 60)))

(qt-widget-add-stretch root)

(defun on-event ()
  { (recv
      ((button-pressed (? h))
       (cond
         ((= h btn-hide)    (qt-widget-set-visible  target nil))
         ((= h btn-show)    (qt-widget-set-visible  target t))
         ((= h btn-disable) (qt-widget-set-enabled  target nil))
         ((= h btn-enable)  (qt-widget-set-enabled  target t))
         ((= h btn-reveal)  (qt-widget-set-visible  secret t))
         ((= h btn-red)     (qt-widget-set-style    target "background-color: #aa2222; color: #ffffff;"))
         ((= h btn-green)   (qt-widget-set-style    target "background-color: #22aa44; color: #ffffff;"))
         ((= h btn-reset)   (qt-widget-set-style    target ""))
         ((= h styled)      (print "visible:" (qt-widget-get-visible target)
                                   "enabled:" (qt-widget-get-enabled target)))))
      ((? _) (print "unhandled")))
    (on-event) })

(event-register-handler (spawn on-event))
