(def root (qt-root))

(def grp (qt-widget-add-container root 'vbox))
(def r1 (qt-widget-add-radio grp "Option A"))
(def r2 (qt-widget-add-radio grp "Option B"))

(def si (qt-widget-add-spinbox-i root 0 100))
(def sf (qt-widget-add-spinbox-f root -1.0 1.0 0.01))

(def tf (qt-widget-add-textfield root "Enter name..."))

(defun on-event ()
  { (recv
      ((radio-changed    (? h))       (print h))
      ((spinbox-changed  (? h) (? v)) (print h v))
      ((textfield-commit (? h) (? s)) (print h s)))
    (on-event) })

(event-register-handler (spawn on-event))
